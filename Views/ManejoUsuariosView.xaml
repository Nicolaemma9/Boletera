<Window x:Class="Boletera.Views.ManejoUsuariosView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        
        xmlns:vm="clr-namespace:Boletera.ViewModel"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Boletera.Views"
        mc:Ignorable="d"
        Title="Gestion de los usuarios" Height="650" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:ManejoUsuariosViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Margin="0,0,0,15">

            <!-- RECTÁNGULO 1 (TÍTULO Y SUBTÍTULO) -->
            <Border Background="#1E3A8A"
            CornerRadius="5"
            Padding="20"
            Margin="0,0,0,10">

                <StackPanel>
                    <TextBlock Text="👤 Gestión de Usuarios"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"/>

                    <TextBlock Text="Administra los usuarios del cine"
                       Foreground="#D1D5DB"
                       FontSize="14"
                       Margin="0,5,0,0"/>
                </StackPanel>

            </Border>

            <!-- RECTÁNGULO 2 (BOTONES) -->
            <Border Background="#1E3A8A"
            CornerRadius="5"
            Padding="20">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cerrar Sesión (Izquierda) -->
                    <Button Grid.Column="0"
                    Click="Button_Click"
                    Content="Cerrar Sesión"
                    Height="40"
                    Width="140"
                    Background="#8B0000"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>

                    <!-- Refrescar (Derecha) -->
                    <Button Grid.Column="3"
                    Content="Refrescar"
                    Command="{Binding RefreshCommand}"
                    Height="40"
                    Width="140"
                    Margin="10,0,0,0"
                    Background="#2563EB"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>

                    <!-- Cambiar nuevo boton -->
                    <Button Grid.Column="2"
                    Click="Button_Click_1"
                    Content="Cambiar a G. Pelicula"
                    Height="40"
                    Width="140"
                    Margin="10,0,0,0"
                    Background="#F59E0B"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>

                    <!-- Agregar (Derecha) -->
                    <Button Grid.Column="4"
                    Content="Agregar Usuario"
                    Command="{Binding AddCommand}"
                    Height="40"
                    Width="140"
                    Margin="10,0,0,0"
                    Background="#22C55E"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>

                </Grid>

            </Border>

        </StackPanel>

        <!-- TABLA -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="15"
                Padding="15"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Margin="0,0,0,15">

            <DataGrid ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      RowHeight="35"
                      GridLinesVisibility="None"
                      AlternatingRowBackground="#F9FAFB"
                      Background="White"
                      BorderThickness="0"
                      FontSize="14">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E0E7FF"/>
                        <Setter Property="Foreground" Value="#1E3A8A"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,0,0,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,0,0,0"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Nombre del Usuario" Binding="{Binding UserName}" Width="*"/>
                    <DataGridTextColumn Header="Apellido" Binding="{Binding LastName}" Width="100"/>
                    <DataGridTextColumn Header="Correo Electronico" Binding="{Binding Email}" Width="150"/>


                    <DataGridTemplateColumn Header="Acciones" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Eliminar"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Background="#DC2626"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Height="30"
                                        Width="90"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

        </Border>

        <!-- PANEL DE EDICIÓN -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="15"
                Padding="15"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>

                <TextBlock Text="✏ Editar Usuario seleccionado"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#111827"
                           Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>


                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Nombre -->
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Usuario" FontWeight="Bold" Foreground="#374151"/>
                        <TextBox Height="35"
                                 Padding="10"
                                 Background="#F3F4F6"
                                 BorderThickness="0"
                                 Text="{Binding SelectedUser.UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Apellido -->
                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Apellido" FontWeight="Bold" Foreground="#374151"/>
                        <TextBox Height="35"
                                 Padding="10"
                                 Background="#F3F4F6"
                                 BorderThickness="0"
                                 Text="{Binding SelectedUser.LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Correo Electronico -->
                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="Correo Electronico" FontWeight="Bold" Foreground="#374151"/>
                        <TextBox Height="35"
                                 Padding="10"
                                 Background="#F3F4F6"
                                 BorderThickness="0"
                                 Text="{Binding SelectedUser.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>




                    <!-- Guardar -->
                    <Button Grid.Column="6"
                            Content="Guardar"
                            Command="{Binding EditCommand}"
                            CommandParameter="{Binding SelectedUser}"
                            Background="#2563EB"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Height="40"
                            Width="140"
                            Margin="10,20,0,0"/>
                </Grid>

            </StackPanel>
        </Border>

    </Grid>

</Window>