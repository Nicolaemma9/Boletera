<Window x:Class="Boletera.Views.RegistroView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Boletera.Views"
        xmlns:ViewModels ="clr-namespace:Boletera.ViewModel"
        xmlns:CustomControls ="clr-namespace:Boletera.CustomControls"
        mc:Ignorable="d"
        Title="RegistroView" Height="450" Width="800">


    <Window.DataContext>
        <ViewModels:RegistroViewModel/>
    </Window.DataContext>

    <!-- FONDO -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1E3A8A" Offset="0"/>
                <GradientStop Color="#2563EB" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- TARJETA CENTRAL -->
        <Border Width="450"
                Padding="35"
                CornerRadius="5"
                Background="White"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

                <StackPanel>

                    <!-- TITULO -->
                    <TextBlock Text="Registro"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="#1E3A8A"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Crear nueva cuenta"
                               FontSize="14"
                               Foreground="#6B7280"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,25"/>

                    <!-- USUARIO -->
                    <TextBlock Text="Usuario"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <TextBox Height="40"
                             FontSize="14"
                             Padding="10"
                             Background="#F3F4F6"
                             BorderThickness="0"
                             Margin="0,0,0,15"
                             Text="{Binding User.UserName, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- CONTRASEÑA -->
                    <TextBlock Text="Contraseña"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <TextBox Height="40"
                             FontSize="14"
                             Padding="10"
                             Background="#F3F4F6"
                             BorderThickness="0"
                             Margin="0,0,0,15"
                             Text="{Binding User.Password, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- CONFIRMAR CONTRASEÑA -->
                    <TextBlock Text="Confirmar Contraseña"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <TextBox Height="40"
                             FontSize="14"
                             Padding="10"
                             Background="#F3F4F6"
                             BorderThickness="0"
                             Margin="0,0,0,15"
                             Text="{Binding User.ConfirmPassword, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- NOMBRE -->
                    <TextBlock Text="Nombre"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <TextBox Height="40"
                             FontSize="14"
                             Padding="10"
                             Background="#F3F4F6"
                             BorderThickness="0"
                             Margin="0,0,0,15"
                             Text="{Binding User.Name, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- APELLIDO -->
                    <TextBlock Text="Apellido"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <TextBox Height="40"
                             FontSize="14"
                             Padding="10"
                             Background="#F3F4F6"
                             BorderThickness="0"
                             Margin="0,0,0,15"
                             Text="{Binding User.LastName, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- EMAIL -->
                    <TextBlock Text="Correo electrónico"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <TextBox Height="40"
                             FontSize="14"
                             Padding="10"
                             Background="#F3F4F6"
                             BorderThickness="0"
                             Margin="0,0,0,15"
                             Text="{Binding User.Email, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- ERROR -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#DC2626"
                               FontWeight="SemiBold"
                               Margin="0,5,0,10"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>

                    <!-- BOTÓN REGISTRAR -->
                    <Button Content="Registrar"
                            Height="45"
                            Margin="0,10,0,10"
                            Background="#2563EB"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding AddCommand}"/>

                    <!-- BOTÓN CANCELAR -->
                    <Button Content="Volver al Login"
                            Height="40"
                            Background="Transparent"
                            BorderBrush="#2563EB"
                            BorderThickness="2"
                            Foreground="#2563EB"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Click="BtnCancelar_Click"/>

                </StackPanel>
            </ScrollViewer>

        </Border>
    </Grid>


</Window>
