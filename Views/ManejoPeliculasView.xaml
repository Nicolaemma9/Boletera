<Window x:Class="Boletera.Views.ManejoPeliculasView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        
        xmlns:vm="clr-namespace:Boletera.ViewModel"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Boletera.Views"
        mc:Ignorable="d"
        Title="Gestion de las peliculas" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:ManejoPeliculaViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#1E3A8A"
                CornerRadius="5"
                Padding="20"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="🎬 Gestión de Películas"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>

                    <TextBlock Text="Administra la cartelera del cine"
                               Foreground="#D1D5DB"
                               FontSize="14"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Refrescar"
                        Command="{Binding RefreshCommand}"
                        Height="40"
                        Width="140"
                        Margin="10,0"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"/>

                <Button Grid.Column="2"
                        Content="Agregar"
                        Command="{Binding AddCommand}"
                        Height="40"
                        Width="140"
                        Margin="10,0,0,0"
                        Background="#22C55E"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- TABLA -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="15"
                Padding="15"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Margin="0,0,0,15">

            <DataGrid ItemsSource="{Binding Pelicula}"
                      SelectedItem="{Binding PeliculaSellecionada}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      RowHeight="35"
                      GridLinesVisibility="None"
                      AlternatingRowBackground="#F9FAFB"
                      Background="White"
                      BorderThickness="0"
                      FontSize="14">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E0E7FF"/>
                        <Setter Property="Foreground" Value="#1E3A8A"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,0,0,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,0,0,0"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Película" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Precio" Binding="{Binding Precio}" Width="100"/>
                    <DataGridTextColumn Header="Sala" Binding="{Binding Sala}" Width="90"/>
                    <DataGridTextColumn Header="Idioma" Binding="{Binding Idioma}" Width="120"/>
                    <DataGridTextColumn Header="Subtítulos" Binding="{Binding Subtitulos}" Width="120"/>
                    <DataGridTextColumn Header="Horarios" Binding="{Binding Horarios}" Width="160"/>

                    <DataGridTemplateColumn Header="Acciones" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Eliminar"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Background="#DC2626"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Height="30"
                                        Width="90"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

        </Border>

        <!-- PANEL DE EDICIÓN -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="15"
                Padding="15"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>

                <TextBlock Text="✏ Editar película seleccionada"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#111827"
                           Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Nombre -->
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Película" FontWeight="Bold" Foreground="#374151"/>
                        <TextBox Height="35"
                                 Padding="10"
                                 Background="#F3F4F6"
                                 BorderThickness="0"
                                 Text="{Binding PeliculaSellecionada.Nombre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Precio -->
                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Precio" FontWeight="Bold" Foreground="#374151"/>
                        <TextBox Height="35"
                                 Padding="10"
                                 Background="#F3F4F6"
                                 BorderThickness="0"
                                 Text="{Binding PeliculaSellecionada.Precio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Sala -->
                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="Sala" FontWeight="Bold" Foreground="#374151"/>
                        <TextBox Height="35"
                                 Padding="10"
                                 Background="#F3F4F6"
                                 BorderThickness="0"
                                 Text="{Binding PeliculaSellecionada.Sala, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Idioma -->
                    <StackPanel Grid.Column="3" Margin="5">
                        <TextBlock Text="Idioma" FontWeight="Bold" Foreground="#374151"/>
                        <TextBox Height="35"
                                 Padding="10"
                                 Background="#F3F4F6"
                                 BorderThickness="0"
                                 Text="{Binding PeliculaSellecionada.Idioma, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Subtitulos -->
                    <StackPanel Grid.Column="4" Margin="5">
                        <TextBlock Text="Subtítulos" FontWeight="Bold" Foreground="#374151"/>
                        <TextBox Height="35"
                                 Padding="10"
                                 Background="#F3F4F6"
                                 BorderThickness="0"
                                 Text="{Binding PeliculaSellecionada.Subtitulos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Horarios -->
                    <StackPanel Grid.Column="5" Margin="5">
                        <TextBlock Text="Horarios" FontWeight="Bold" Foreground="#374151"/>
                        <TextBox Height="35"
                                 Padding="10"
                                 Background="#F3F4F6"
                                 BorderThickness="0"
                                 Text="{Binding PeliculaSellecionada.Horarios, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Guardar -->
                    <Button Grid.Column="6"
                            Content="Guardar"
                            Command="{Binding EditCommand}"
                            CommandParameter="{Binding PeliculaSellecionada}"
                            Background="#2563EB"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Height="40"
                            Width="140"
                            Margin="10,20,0,0"/>
                </Grid>

            </StackPanel>
        </Border>

    </Grid>

</Window>
